  local bindir="$1"
  local pr_log="$2"

  write_stubs "$bindir" 90 "$pr_log"

  cat > "$bindir/gh" <<GH
#!/usr/bin/env bash
set -euo pipefail

if [[ "\${1:-}" == "api" ]]; then
  case "\${2:-}" in
    repos/actions/checkout/releases/latest)
      printf 'v4\\n'
      ;;
    repos/actions/checkout)
      printf 'main\\n'
      ;;
    repos/actions/checkout/releases/tags/v4)
      printf 'null\\n'
      ;;
    repos/actions/checkout/compare/v2...v4)
      printf 'abc1234\\tHarden checkout token handling\\thttps://github.com/actions/checkout/commit/abc1234\\n'
      ;;
    *)
      printf 'unexpected gh api endpoint: %s\\n' "\${2:-}" >&2
      exit 1
      ;;
  esac
elif [[ "\${1:-}" == "pr" && "\${2:-}" == "create" ]]; then
  printf '%s\\n' "\$*" > "$pr_log"
else
  printf 'unexpected gh args: %s\\n' "\$*" >&2
  exit 1
fi
GH

  chmod +x "$bindir/gh"
}

init_workflow_repo() {
  local repo="$1"

  mkdir -p "$repo/.github/workflows"
  cat > "$repo/.github/workflows/build.yml" <<'YAML'
name: test
on: workflow_dispatch
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
YAML

  git -C "$repo" init -q -b main
  git -C "$repo" config user.email test@example.com
  git -C "$repo" config user.name Test
  git -C "$repo" add .github/workflows/build.yml
  git -C "$repo" commit -q -m init
}

init_multi_finding_repo() {
  local repo="$1"

  mkdir -p "$repo/.github/workflows"
  cat > "$repo/.github/workflows/build.yml" <<'YAML'
name: test
on: workflow_dispatch
jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v2
      - uses: docker/setup-buildx-action@v1
YAML

  git -C "$repo" init -q -b main
  git -C "$repo" config user.email test@example.com
  git -C "$repo" config user.name Test
  git -C "$repo" add .github/workflows/build.yml
  git -C "$repo" commit -q -m init
  git -C "$repo" remote add origin https://github.com/wallentx/actions-snitch-fixture.git
}

