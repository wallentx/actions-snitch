#!/usr/bin/env bash
set -euo pipefail

if [[ "${RUNNER_VERBOSE:-0}" -eq 1 ]]; then
  set -x
fi

ROOT=$(git rev-parse --show-toplevel)
SCRIPT="$ROOT/actions-snitch"
TMP_ROOT=$(mktemp -d "${TMPDIR:-/tmp}/actions-snitch-lint-test.XXXXXXXXXX")

cleanup() {
  rm -rf "$TMP_ROOT"
}
trap cleanup EXIT

fail() {
  printf 'lint-test: %s\n' "$*" >&2
  exit 1
}

run_shellcheck() {
  shellcheck --color=always "$SCRIPT" "$ROOT/.github/scripts/lint-test"
}

run_syntax_checks() {
  bash -n "$SCRIPT"
  bash -n "$ROOT/.github/scripts/lint-test"
}

write_stubs() {
  local bindir="$1"
  local score="$2"
  local pr_log="${3:-}"

  mkdir -p "$bindir"

  cat > "$bindir/gh" <<GH
#!/usr/bin/env bash
set -euo pipefail

if [[ "\${1:-}" == "api" ]]; then
  case "\${2:-}" in
    repos/actions/checkout/releases/latest)
      printf 'v4\\n'
      ;;
    repos/actions/cache/releases/latest)
      printf 'v6\\n'
      ;;
    repos/github/codeql-action/releases/latest)
      printf 'codeql-bundle-v2.23.0\\n'
      ;;
    repos/actions/checkout)
      printf 'main\\n'
      ;;
    repos/actions/cache)
      printf 'main\\n'
      ;;
    repos/actions/checkout/releases/tags/v4)
      printf '## What changed\\n- Harden checkout token handling\\n'
      ;;
    repos/actions/cache/releases/tags/v6)
      printf '## What changed\\n- Improve cache lookup behavior\\n'
      ;;
    repos/actions/checkout/compare/v2...v4)
      printf 'abc1234\\tHarden checkout token handling\\thttps://github.com/actions/checkout/commit/abc1234\\n'
      ;;
    repos/actions/cache/compare/v5...v6)
      printf 'cab6789\\tImprove cache lookup behavior\\thttps://github.com/actions/cache/commit/cab6789\\n'
      ;;
    *)
      printf 'unexpected gh api endpoint: %s\\n' "\${2:-}" >&2
      exit 1
      ;;
  esac
elif [[ "\${1:-}" == "pr" && "\${2:-}" == "create" ]]; then
  printf '%s\\n' "\$*" > "$pr_log"
else
  printf 'unexpected gh args: %s\\n' "\$*" >&2
  exit 1
fi
GH

  cat > "$bindir/curl" <<CURL
#!/usr/bin/env bash
set -euo pipefail

case "\$*" in
  *dependabot-badges.githubapp.com*)
    printf '%s\\n' '<svg><title>compatibility: $score%</title></svg>'
    ;;
  *raw.githubusercontent.com/actions/checkout*/action.y*)
    printf '%s\\n' 'name: Checkout'
    ;;
  *raw.githubusercontent.com/actions/checkout*/CHANGELOG.md*)
    printf '%s\\n' '## v4' '- Harden checkout token handling'
    ;;
  *raw.githubusercontent.com/actions/cache*/action.y*)
    printf '%s\\n' 'name: Cache'
    ;;
  *raw.githubusercontent.com/actions/cache*/CHANGELOG.md*)
    printf '%s\\n' '## v6' '- Improve cache lookup behavior'
    ;;
  *github.com/marketplace/actions/checkout*)
    printf '%s\\n' 'GitHub has manually verified the creator of the action as an official partner organization.'
    ;;
  *github.com/marketplace/actions/cache*)
    printf '%s\\n' 'GitHub has manually verified the creator of the action as an official partner organization.'
    ;;
  *)
    printf 'unexpected curl args: %s\\n' "\$*" >&2
    exit 1
    ;;
esac
CURL

  chmod +x "$bindir/gh" "$bindir/curl"
}

write_multi_action_stubs() {
  local bindir="$1"
  local pr_log="${2:-}"

  mkdir -p "$bindir"

  cat > "$bindir/gh" <<GH
#!/usr/bin/env bash
set -euo pipefail

if [[ "\${1:-}" == "api" ]]; then
  case "\${2:-}" in
    repos/actions/checkout/releases/latest)
      printf 'v4\n'
      ;;
    repos/actions/checkout)
      printf 'main\n'
      ;;
    repos/actions/checkout/releases/tags/v4)
      printf '## What changed\n- Harden checkout token handling\n'
      ;;
    repos/actions/checkout/compare/v2...v4)
      printf 'abc1234\tHarden checkout token handling\thttps://github.com/actions/checkout/commit/abc1234\n'
      ;;
    repos/docker/setup-buildx-action/releases/latest)
      printf 'v3\n'
      ;;
    repos/docker/setup-buildx-action)
      printf 'main\n'
      ;;
    repos/docker/setup-buildx-action/releases/tags/v3)
      printf '## What changed\n- Improve Buildx setup defaults\n'
      ;;
    repos/docker/setup-buildx-action/compare/v1...v3)
      printf 'def5678\tImprove Buildx setup defaults\thttps://github.com/docker/setup-buildx-action/commit/def5678\n'
      ;;
    *)
      printf 'unexpected gh api endpoint: %s\n' "\${2:-}" >&2
      exit 1
      ;;
  esac
elif [[ "\${1:-}" == "pr" && "\${2:-}" == "create" ]]; then
  printf '%s\n' "\$*" > "$pr_log"
else
  printf 'unexpected gh args: %s\n' "\$*" >&2
  exit 1
fi
GH

  cat > "$bindir/curl" <<'CURL'
#!/usr/bin/env bash
set -euo pipefail

case "$*" in
  *dependency-name=actions/checkout*)
    printf '%s\n' '<svg><title>compatibility: 90%</title></svg>'
    ;;
  *dependency-name=docker/setup-buildx-action*)
    printf '%s\n' '<svg><title>compatibility: 50%</title></svg>'
    ;;
  *raw.githubusercontent.com/actions/checkout*/action.y*)
    printf '%s\n' 'name: Checkout'
    ;;
  *raw.githubusercontent.com/actions/checkout*/CHANGELOG.md*)
    printf '%s\n' '## v4' '- Harden checkout token handling'
    ;;
  *raw.githubusercontent.com/docker/setup-buildx-action*/action.y*)
    printf '%s\n' 'name: Docker Setup Buildx'
    ;;
  *raw.githubusercontent.com/docker/setup-buildx-action*/CHANGELOG.md*)
    printf '%s\n' '## v3' '- Improve Buildx setup defaults'
    ;;
  *github.com/marketplace/actions/checkout*)
    printf '%s\n' 'GitHub has manually verified the creator of the action as an official partner organization.'
    ;;
  *github.com/marketplace/actions/docker-setup-buildx*)
    printf '%s\n' 'No verified badge on this page.'
    ;;
  *)
    printf 'unexpected curl args: %s\n' "$*" >&2
    exit 1
    ;;
esac
CURL

  chmod +x "$bindir/gh" "$bindir/curl"
}

write_commit_sha_default_branch_stubs() {
  local bindir="$1"
  local real_git

  real_git=$(command -v git)
  mkdir -p "$bindir"

  cat > "$bindir/gh" <<'GH'
#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "api" ]]; then
  case "${2:-}" in
    repos/actions/checkout/releases/latest)
      exit 1
      ;;
    repos/actions/checkout)
      printf 'main\n'
      ;;
    repos/actions/checkout/commits/main)
      printf 'bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb\n'
      ;;
    *)
      printf 'unexpected gh api endpoint: %s\n' "${2:-}" >&2
      exit 1
      ;;
  esac
else
  printf 'unexpected gh args: %s\n' "$*" >&2
  exit 1
fi
GH

  cat > "$bindir/curl" <<'CURL'
#!/usr/bin/env bash
set -euo pipefail

case "$*" in
  *raw.githubusercontent.com/actions/checkout*/action.y*)
    printf '%s\n' 'name: Checkout'
    ;;
  *github.com/marketplace/actions/checkout*)
    printf '%s\n' 'GitHub has manually verified the creator of the action as an official partner organization.'
    ;;
  *)
    printf 'unexpected curl args: %s\n' "$*" >&2
    exit 1
    ;;
esac
CURL

  cat > "$bindir/git" <<GIT
#!/usr/bin/env bash
set -euo pipefail

if [[ "\${1:-}" == "clone" && "\${2:-}" == "--depth=1" && "\${3:-}" == "https://github.com/actions/checkout.git" ]]; then
  mkdir -p "\$4"
  exit 0
fi

if [[ "\${1:-}" == "fetch" && "\${2:-}" == "origin" ]]; then
  exit 0
fi

if [[ "\${1:-}" == "rev-list" && "\${2:-}" == "--count" ]]; then
  printf '1\n'
  exit 0
fi

exec "$real_git" "\$@"
GIT

  chmod +x "$bindir/gh" "$bindir/curl" "$bindir/git"
}

